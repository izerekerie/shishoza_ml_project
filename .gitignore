data/sector_risk.json              # now results/application/
data/experiment_results.csv        # now results/experiments/
data/feature_importance.png        # now results/experiments/
data/rq1_*.png                     # now results/experiments/
data/rq1_*.md                      # now results/experiments/
data/hp_tuning_*.csv               # now results/hyperparameter_tuning/
data/hp_tuning_*.json              # now results/hyperparameter_tuning/
data/hp_tuning_*.png               # now results/hyperparameter_tuning/
data/confusion_matrix.png          # now results/metrics/
data/results_*.png                 # now results/metrics/
data/evaluation_audit.json         # now results/metrics/
data/patch_size_*.png              # now results/patch_size_analysis/
